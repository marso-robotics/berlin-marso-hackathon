# pixi environments
.pixi/*
!.pixi/config.toml

# JUDGE-ONLY — held-out eval config, never shipped to competitors (BUILD_SPEC §10)
judge/

# run outputs / checkpoints
outputs/
*.pt

# python
__pycache__/
*.pyc
*.egg-info/
.ipynb_checkpoints/

# editor / local settings
.vscode/
.claude/

# IL track generated artifacts (datasets + videos; checkpoints already covered by *.pt)
il/demos/
il/videos/
*.h5
*.mp4
